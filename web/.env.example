# ──── Vercel Dashboard → Settings → Environment Variables ────
# Замени на свой домен при деплое (например https://neocar.md)
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# 3D Hero: модель уже добавлена и оптимизирована (forklift.opt.glb)
# true = включить 3D на проде; false = статичный постер (e2e/тесты)
# На слабых устройствах или если нужен более высокий Lighthouse Performance в локальных прогонах — можно временно поставить false (без 3D Hero).
NEXT_PUBLIC_HERO_USE_GLB=true

# Кастомный путь к GLB-модели (опционально, по умолчанию /models/forklift.opt.glb)
# NEXT_PUBLIC_HERO_GLB_URL=/models/forklift.opt.glb
